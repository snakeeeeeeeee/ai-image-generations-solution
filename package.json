{
  "name": "image-handle",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "OpenAI-compatible image generation wrapper that uploads b64_json images to Cloudflare R2.",
  "scripts": {
    "build": "npm run build:admin && npm run build:server",
    "build:server": "tsc",
    "build:admin": "vite build",
    "start": "node dist/src/index.js",
    "dev": "tsx watch src/index.ts",
    "dev:admin": "vite --host 127.0.0.1",
    "mock:new-api": "tsx scripts/mock-new-api.ts",
    "test": "npm run build:server && node --test dist/test/*.test.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.828.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/static": "^9.1.3",
    "better-sqlite3": "^12.10.0",
    "dotenv": "^16.5.0",
    "fastify": "^5.3.3",
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.29",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^8.0.14"
  }
}
