{
  "name": "image-handle",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "OpenAI-compatible image generation wrapper that uploads b64_json images to Cloudflare R2.",
  "scripts": {
    "build": "tsc",
    "start": "node dist/src/index.js",
    "dev": "tsx watch src/index.ts",
    "mock:new-api": "tsx scripts/mock-new-api.ts",
    "test": "npm run build && node --test dist/test/*.test.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.828.0",
    "dotenv": "^16.5.0",
    "fastify": "^5.3.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
