# 服务监听端口。
PORT=8787

# Docker Compose 映射到宿主机的 image-api 端口。
IMAGE_API_HOST_PORT=8787

# 服务监听地址；服务器部署通常使用 0.0.0.0。
HOST=0.0.0.0

# 日志级别；常用值：trace、debug、info、warn、error。
LOG_LEVEL=info

# 运行角色：
# api 只启动 HTTP API；worker 只启动任务处理进程；notifier 只启动回调投递进程；
# all 适合本地开发，把 API、任务处理和回调投递放在同一进程。
IMAGE_HANDLE_ROLE=api

# PostgreSQL 是异步任务事实库。多机部署时所有节点必须指向同一个库。
POSTGRES_URL=postgres://image_handle:image_handle@image-handle-postgres:5432/image_handle

# 本地 Docker Compose 暴露到宿主机的 PostgreSQL 端口。
POSTGRES_HOST_PORT=5432

# Redis 用于 BullMQ 队列、分布式限速、短期协调。多机部署时所有节点必须指向同一个 Redis。
REDIS_URL=redis://image-handle-redis:6379

# 本地 Docker Compose 暴露到宿主机的 Redis 端口。
REDIS_HOST_PORT=6379

# 允许 new-api 调用 /v1/image/tasks 的服务鉴权 key。多个 key 用英文逗号分隔。
PROVIDER_API_KEYS=provider-test-key

# 最大同时在途的图片请求数，包含等待 new-api/OpenAI 返回的阶段。
MAX_CONCURRENT_GENERATIONS=1000

# 最大同时进行图片解码和 R2 上传的数量；这个阶段更吃内存。
MAX_CONCURRENT_IMAGE_PROCESSING=50

# 进程 RSS 内存保护阈值，单位 MB；超过后拒绝新的图片任务。
MAX_PROCESS_RSS_MB=28672

# new-api 的基础地址；本地冒烟测试可用 http://127.0.0.1:3999。
# 生产环境建议填同机器或内网 new-api 地址，避免公网绕路。
NEW_API_BASE_URL=http://127.0.0.1:3000

# 本地 Docker Compose mock-new-api 的容器内端口和宿主机端口。
MOCK_NEW_API_PORT=3999
MOCK_NEW_API_HOST_PORT=3999

# 文生图上游路径；默认兼容 OpenAI /v1/images/generations。
NEW_API_IMAGES_PATH=/v1/images/generations

# 图生图/编辑图上游路径；默认兼容 OpenAI /v1/images/edits。
NEW_API_IMAGES_EDITS_PATH=/v1/images/edits

# 请求 new-api 的超时时间，单位毫秒；1800000 = 30 分钟。
UPSTREAM_TIMEOUT_MS=1800000

# 同步兼容接口需要服务侧固定鉴权时可配置；为空时同步接口转发调用方 Authorization。
# 异步任务使用 credential lease，worker 领取短期凭证后直连真实上游；该 key 只影响同步兼容接口。
UPSTREAM_API_KEY=

# 图片 API 跨域允许的来源；纯 API Key 调用可用 *，多个域名用英文逗号分隔。
CORS_ALLOWED_ORIGINS=*

# 浏览器 CORS 预检缓存时间，单位秒；86400 = 1 天。
CORS_MAX_AGE_SECONDS=86400

# 图片默认尺寸；用户未传 size 时使用这个值。
DEFAULT_IMAGE_SIZE=2560x1440

# 强制上游输出格式；可用 png、jpeg、webp。同步兼容场景默认 png。
DEFAULT_OUTPUT_FORMAT=png

# Cloudflare R2 S3 兼容 API Endpoint。
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com

# Cloudflare R2 Access Key ID；不要把真实值提交到仓库。
R2_ACCESS_KEY_ID=

# Cloudflare R2 Secret Access Key；不要把真实值提交到仓库。
R2_SECRET_ACCESS_KEY=

# R2 Bucket 名称。
R2_BUCKET=<bucket-name>

# R2 公开访问域名或 CDN 域名；返回给用户的 URL 会基于这个前缀生成。
R2_PUBLIC_URL=https://<public-image-domain>

# R2 对象 key 前缀；建议保持 images，方便生命周期规则按前缀清理。
R2_KEY_PREFIX=images

# 上传对象的缓存头；配合 CDN 缓存使用。
R2_CACHE_CONTROL=public, max-age=86400

# 本地 MinIO 等 S3 兼容服务通常需要 true；Cloudflare R2 通常使用 false。
R2_FORCE_PATH_STYLE=false

# R2 上传失败后的最大重试次数；3 表示失败后最多再试 3 次。
R2_UPLOAD_MAX_RETRIES=3

# R2 上传指数退避的初始等待时间，单位毫秒。
R2_UPLOAD_RETRY_BASE_DELAY_MS=300

# R2 上传指数退避的最大等待时间，单位毫秒。
R2_UPLOAD_RETRY_MAX_DELAY_MS=3000

# 管理台访问路径；需要和 nginx 代理路径、Vite base 保持一致。
ADMIN_BASE_PATH=/image-wrapper/admin

# 管理台登录密码；生产环境必须设置强密码。
ADMIN_PASSWORD=

# 管理台会话签名密钥；生产环境必须固定设置，建议使用随机 32 字节以上字符串。
ADMIN_SESSION_SECRET=

# 管理台 SQLite 数据库路径；用于保存最近请求指标和排空模式状态。
ADMIN_DB_PATH=./data/admin.sqlite

# 管理台请求记录保留天数；超过后会自动清理。
ADMIN_RETENTION_DAYS=7

# 管理台默认最近记录查询上限；分页接口仍会按 page_size 返回。
ADMIN_RECENT_LIMIT=1000

# 异步任务处理并发；请求上游阶段主要受上游 IPM 限制。
WORKER_CONCURRENCY=20

# 同时进行图片解码/R2 上传的异步任务数；这个阶段主要受内存限制。
IMAGE_PROCESSING_CONCURRENCY=10

# 默认全局上游限速，单位 images per minute。
GLOBAL_RATE_LIMIT_IPM=250

# 更细粒度限速配置。异步 direct lease 模式下按 resolve 后的 provider/model/channel_id 限速；
# key 可为 provider、provider:model、provider:model:channel_id。
PROVIDER_RATE_LIMIT_CONFIG_JSON={}

# 回调批量投递配置。
CALLBACK_BATCH_SIZE=50
CALLBACK_FLUSH_MS=2000
CALLBACK_MAX_RETRY_AGE_HOURS=24

# 回调密钥。CALLBACK_SECRETS_JSON 按 secret_id 映射真实密钥；
# 不存在映射时使用 CALLBACK_DEFAULT_SECRET。
CALLBACK_DEFAULT_SECRET=local-callback-secret
CALLBACK_SECRETS_JSON={}

# credential lease resolve 签名密钥。key 是 executor.secret_id，必须与 new-api 侧一致。
CREDENTIAL_LEASE_SECRETS_JSON={"image_handle_1":"local-credential-lease-secret"}

# 允许 image-handle worker 调用的 executor.resolve_url host 白名单，多个用英文逗号分隔。
# 为空时默认使用 NEW_API_BASE_URL 的 host。
CREDENTIAL_LEASE_ALLOWED_HOSTS=127.0.0.1:3000

# callback/query 中保留的安全版上游原始响应大小上限，单位字节；b64_json/data URI 等大字段会被剔除。
RAW_RESPONSE_MAX_BYTES=262144

# 同步等待包装接口配置。超时后任务继续在后台执行，接口返回 processing，new-api 用 callback/查询兜底。
SYNC_TASK_TIMEOUT_MS=300000
SYNC_TASK_POLL_INTERVAL_MS=500
SYNC_WAIT_CONCURRENCY=200

# worker 运行态心跳配置；管理台通过 Redis TTL 心跳展示在线 worker 和当前任务。
WORKER_HEARTBEAT_INTERVAL_MS=5000
WORKER_HEARTBEAT_TTL_SECONDS=15

# 任务处理进程异常退出后，processing 超过该时间会被重新置为 queued 并补偿入队。
TASK_STALE_PROCESSING_TIMEOUT_SECONDS=1800
