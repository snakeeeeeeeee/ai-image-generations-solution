PORT=8787
HOST=0.0.0.0
LOG_LEVEL=info
MAX_CONCURRENT_GENERATIONS=1000
MAX_CONCURRENT_IMAGE_PROCESSING=50

# For local smoke test, use http://127.0.0.1:3999 with `npm run mock:new-api`.
# On the production new-api host, use the local/internal new-api address.
NEW_API_BASE_URL=http://127.0.0.1:3000
NEW_API_IMAGES_PATH=/v1/images/generations
UPSTREAM_TIMEOUT_MS=1800000

# Defaults applied to incoming OpenAI-style image requests.
DEFAULT_IMAGE_SIZE=2560x1440
DEFAULT_OUTPUT_FORMAT=png

# Cloudflare R2 S3-compatible settings.
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=<bucket-name>
R2_PUBLIC_URL=https://<public-image-domain>
R2_KEY_PREFIX=images
R2_CACHE_CONTROL=public, max-age=86400
