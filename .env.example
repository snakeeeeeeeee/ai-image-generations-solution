# 服务监听端口。
PORT=8787

# 服务监听地址；服务器部署通常使用 0.0.0.0。
HOST=0.0.0.0

# 日志级别；常用值：trace、debug、info、warn、error。
LOG_LEVEL=info

# 最大同时在途的图片请求数，包含等待 new-api/OpenAI 返回的阶段。
MAX_CONCURRENT_GENERATIONS=1000

# 最大同时进行图片解码和 R2 上传的数量；这个阶段更吃内存。
MAX_CONCURRENT_IMAGE_PROCESSING=50

# 进程 RSS 内存保护阈值，单位 MB；超过后拒绝新的图片任务。
MAX_PROCESS_RSS_MB=28672

# new-api 的基础地址；本地冒烟测试可用 http://127.0.0.1:3999。
# 生产环境建议填同机器或内网 new-api 地址，避免公网绕路。
NEW_API_BASE_URL=http://127.0.0.1:3000

# 文生图上游路径；默认兼容 OpenAI /v1/images/generations。
NEW_API_IMAGES_PATH=/v1/images/generations

# 图生图/编辑图上游路径；默认兼容 OpenAI /v1/images/edits。
NEW_API_IMAGES_EDITS_PATH=/v1/images/edits

# 请求 new-api 的超时时间，单位毫秒；1800000 = 30 分钟。
UPSTREAM_TIMEOUT_MS=1800000

# 图片默认尺寸；用户未传 size 时使用这个值。
DEFAULT_IMAGE_SIZE=2560x1440

# 强制上游输出格式；当前服务按 PNG 校验和上传。
DEFAULT_OUTPUT_FORMAT=png

# Cloudflare R2 S3 兼容 API Endpoint。
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com

# Cloudflare R2 Access Key ID；不要把真实值提交到仓库。
R2_ACCESS_KEY_ID=

# Cloudflare R2 Secret Access Key；不要把真实值提交到仓库。
R2_SECRET_ACCESS_KEY=

# R2 Bucket 名称。
R2_BUCKET=<bucket-name>

# R2 公开访问域名或 CDN 域名；返回给用户的 URL 会基于这个前缀生成。
R2_PUBLIC_URL=https://<public-image-domain>

# R2 对象 key 前缀；建议保持 images，方便生命周期规则按前缀清理。
R2_KEY_PREFIX=images

# 上传对象的缓存头；配合 CDN 缓存使用。
R2_CACHE_CONTROL=public, max-age=86400

# R2 上传失败后的最大重试次数；3 表示失败后最多再试 3 次。
R2_UPLOAD_MAX_RETRIES=3

# R2 上传指数退避的初始等待时间，单位毫秒。
R2_UPLOAD_RETRY_BASE_DELAY_MS=300

# R2 上传指数退避的最大等待时间，单位毫秒。
R2_UPLOAD_RETRY_MAX_DELAY_MS=3000

# 管理台访问路径；需要和 nginx 代理路径、Vite base 保持一致。
ADMIN_BASE_PATH=/image-wrapper/admin

# 管理台登录密码；生产环境必须设置强密码。
ADMIN_PASSWORD=

# 管理台会话签名密钥；生产环境必须固定设置，建议使用随机 32 字节以上字符串。
ADMIN_SESSION_SECRET=

# 管理台 SQLite 数据库路径；用于保存最近请求指标和排空模式状态。
ADMIN_DB_PATH=./data/admin.sqlite

# 管理台请求记录保留天数；超过后会自动清理。
ADMIN_RETENTION_DAYS=7

# 管理台默认最近记录查询上限；分页接口仍会按 page_size 返回。
ADMIN_RECENT_LIMIT=1000
