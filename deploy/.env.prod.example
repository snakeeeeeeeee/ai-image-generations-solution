# 复制为 deploy/.env 用于生产环境。不要提交 deploy/.env。

COMPOSE_PROJECT_NAME=image-handle-prod
IMAGE_HANDLE_IMAGE=registry.example.com/image-handle:latest
IMAGE_HANDLE_ENV_FILE=./.env

PORT=8787
HOST=0.0.0.0
IMAGE_API_HOST_PORT=8787
LOG_LEVEL=info

# 生产环境必须使用共享外部 PostgreSQL 和 Redis。
# 如果主节点用 deploy 里的 PG/Redis 容器，保持下面容器内地址即可。
# 如果使用云数据库或独立数据库机器，改成对应内网地址。
POSTGRES_DB=image_handle
POSTGRES_USER=image_handle
POSTGRES_PASSWORD=replace-with-strong-postgres-password
POSTGRES_BIND_ADDR=0.0.0.0
POSTGRES_HOST_PORT=5432
REDIS_PASSWORD=replace-with-strong-redis-password
REDIS_BIND_ADDR=0.0.0.0
REDIS_HOST_PORT=6379
POSTGRES_URL=postgres://image_handle:replace-with-strong-postgres-password@image-handle-postgres:5432/image_handle
REDIS_URL=redis://:replace-with-strong-redis-password@image-handle-redis:6379

# image-handle 接收 new-api 请求的服务鉴权 key。多个 key 用英文逗号分隔，便于轮换。
PROVIDER_API_KEYS=replace-with-provider-key

# 真实 new-api/OpenAI 兼容图片接口地址。
NEW_API_BASE_URL=http://new-api.example.internal:3000
NEW_API_IMAGES_PATH=/v1/images/generations
NEW_API_IMAGES_EDITS_PATH=/v1/images/edits
UPSTREAM_TIMEOUT_MS=1800000
UPSTREAM_API_KEY=replace-with-upstream-key

MAX_CONCURRENT_GENERATIONS=1000
MAX_CONCURRENT_IMAGE_PROCESSING=50
MAX_PROCESS_RSS_MB=28672
REQUEST_BODY_LIMIT_BYTES=104857600

CORS_ALLOWED_ORIGINS=*
CORS_MAX_AGE_SECONDS=86400

DEFAULT_IMAGE_SIZE=2560x1440
DEFAULT_OUTPUT_FORMAT=png

R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=replace-with-r2-access-key-id
R2_SECRET_ACCESS_KEY=replace-with-r2-secret-access-key
R2_BUCKET=<bucket-name>
R2_PUBLIC_URL=https://<public-image-domain>
R2_KEY_PREFIX=images
R2_CACHE_CONTROL=public, max-age=86400
R2_FORCE_PATH_STYLE=false
R2_UPLOAD_MAX_RETRIES=3
R2_UPLOAD_RETRY_BASE_DELAY_MS=300
R2_UPLOAD_RETRY_MAX_DELAY_MS=3000

ADMIN_BASE_PATH=/image-wrapper/admin
ADMIN_PASSWORD=replace-with-admin-password
ADMIN_SESSION_SECRET=replace-with-long-random-session-secret
ADMIN_DB_PATH=./data/admin.sqlite
ADMIN_RETENTION_DAYS=7
ADMIN_RECENT_LIMIT=1000

WORKER_CONCURRENCY=20
IMAGE_PROCESSING_CONCURRENCY=10
GLOBAL_RATE_LIMIT_IPM=250
PROVIDER_RATE_LIMIT_CONFIG_JSON={}
CALLBACK_BATCH_SIZE=50
CALLBACK_FLUSH_MS=2000
CALLBACK_MAX_RETRY_AGE_HOURS=24
CALLBACK_DEFAULT_SECRET=replace-with-callback-secret
CALLBACK_SECRETS_JSON={}
TASK_STALE_PROCESSING_TIMEOUT_SECONDS=1800
